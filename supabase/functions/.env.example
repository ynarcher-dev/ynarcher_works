# Edge Functions(서버) 전용 시크릿 — 절대 VITE_ 접두사 금지, 클라이언트 노출 금지.
# 로컬 서빙: pnpm functions:serve --env-file supabase/functions/.env.local
# 실제 값은 .env.local 에 작성하며 커밋하지 않습니다.

# 서버 전용 Supabase 키 (service_role은 RLS를 우회하는 권한 — 취급 주의)
SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key: `pnpm db:status`로 확인>"

# 게스트 커스텀 JWT 서명 시크릿 (OTP/매직링크 발급-검증)
GUEST_JWT_SECRET="<강력한 랜덤 시크릿>"

# S3 Presigned URL 발급용 자격증명 (첨부파일 업로드)
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID="<access-key>"
AWS_SECRET_ACCESS_KEY="<secret-key>"
S3_ATTACHMENTS_BUCKET="ynarcher-works-attachments"
