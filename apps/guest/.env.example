# GUEST 앱 공개 환경 변수
# Vite는 VITE_ 접두사 변수만 클라이언트 번들에 주입합니다. 서버 시크릿은 절대 여기에 두지 않습니다.
# 실제 값은 .env.local 에 작성하며 커밋하지 않습니다. (root .gitignore가 .env* 제외)

# Supabase 공개 접속 정보 (anon key는 RLS로 보호되는 공개 키)
VITE_SUPABASE_URL="http://127.0.0.1:54321"
VITE_SUPABASE_ANON_KEY="<local-anon-key: `pnpm db:status`로 확인>"

# 앱 실행 환경 (local | development | production)
VITE_APP_ENV="local"
